{
  "name": "clockfycli",
  "version": "0.1.0",
  "description": "Interactive CLI to log time entries to Clockify",
  "type": "module",
  "bin": {
    "clockfycli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clockfycli": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
